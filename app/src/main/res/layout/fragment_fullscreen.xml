<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/frameLayout2"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_world_gradient"
    tools:context=".FullscreenFragment">

    <!--Temporärer Würfel Button basierend auf dem aktuellen UI Sketch-->
    <LinearLayout
        android:id="@+id/rollDiceBtn"
        android:layout_width="160dp"
        android:layout_height="170dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="220dp"
        android:background="@drawable/bg_dice_tile"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/diceIcon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:contentDescription="Dice icon"
            android:src="@drawable/dice_icon" />

        <TextView
            android:id="@+id/rollDiceText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="ROLL DICE"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!--Anzeige des aktuellen Würfelergebnisses-->
    <TextView
        android:id="@+id/diceResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:text="Würfelergebnis: -"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rollDiceBtn" />

    <!--Anzeige von Nachrichten vom Server-->
    <TextView
        android:id="@+id/responseView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:text="Server-Antwort: -"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/diceResult"/>

</androidx.constraintlayout.widget.ConstraintLayout>